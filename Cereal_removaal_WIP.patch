-                               && !traits::has_load_and_construct<T, Archive>::value)
-                               || std::is_abstract<T>::value, bool>::type
-    serialize_wrapper(Archive &, std::unique_ptr<T, D> &, std::uint32_t const nameid)
-    {
-      if(nameid & detail::msb2_32bit)
