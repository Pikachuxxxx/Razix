-  std::cout << std::endl;
-  std::cout << boost::format("\tload | time: %06.4fms (%1.2f) total: %6.1fms")
-    % averageBoostLoad % 1.0 % static_cast<double>( std::chrono::duration_cast<std::chrono::milliseconds>(totalBoostLoad).count() );
-  std::cout << std::endl;
-
-  std::cout << "  Cereal results:" << std::endl;
