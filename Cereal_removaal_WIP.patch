-      totalBoostSave += saveResult;
-      if(!boostSize)
-        boostSize = os.tellp();
-
-      auto loadResult = loadData<DataTBoost>( os, {SerializationT::boost::template load<DataTBoost>} );
-      totalBoostLoad += loadResult.second;
-    }
-
-    // Cereal
-    {
